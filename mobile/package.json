{
  "name": "localagent-companion",
  "version": "0.2.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "web": "expo start --web",
    "ios": "expo run:ios",
    "build:debug": "cd android && gradlew.bat assembleDebug",
    "build:release": "cd android && gradlew.bat assembleRelease",
    "install:debug": "powershell -ExecutionPolicy Bypass -File ..\\tools\\install-android-apk.ps1 -Variant debug -GrantPermissions",
    "install:release": "powershell -ExecutionPolicy Bypass -File ..\\tools\\install-android-apk.ps1 -Variant release -GrantPermissions"
  },
  "dependencies": {
    "@react-navigation/native": "^7.3.1",
    "@react-navigation/native-stack": "^7.17.3",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-camera": "~17.0.10",
    "expo-file-system": "~19.0.22",
    "expo-image-picker": "~17.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}

