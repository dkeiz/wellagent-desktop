  "providers": {
    "ollama": {
      "label": "Ollama",
      "description": "Local Ollama server with model-specific reasoning behavior and adjustable context size.",
      "catalog": ["llama3.2", "qwen3:latest", "qwq:latest", "deepseek-r1:latest"],
      "settings": {
        "supportsModes": false,
        "supportsCustomModel": true,
        "supportsModelDiscovery": true,
        "supportsRequestOverrides": false,
        "customModelLabel": "Custom Model",
        "customModelPlaceholder": "e.g. deepseek-v3.2:cloud",
        "customModelHelp": "Use this for manually pulled Ollama tags or cloud model aliases.",
        "connectionFields": []
      },
      "runtime": {
        "contextWindow": {
          "value": 8192
        },
        "streaming": {
          "text": false,
          "reasoning": false
        }
      },
      "capabilities": {
        "streaming": {
          "text": true,
          "reasoning": "inline"
        },
        "contextWindow": {
          "supported": true,
          "configurable": true
        }
      },
      "notes": [],
      "models": [
        {
          "id": "ollama-qwen-reasoning",
          "label": "Qwen / QwQ Reasoning",
          "match": ["qwen3*", "qwen2.5*", "qwen*", "qwq*"],
          "runtime": {
            "reasoning": {
              "enabled": true
            }
          },
          "capabilities": {
            "reasoning": {
              "supported": true,
              "toggle": true,
              "outputChannel": "inline",
              "parameterMode": "slash_commands",
              "defaultEnabled": true
            }
          },
          "notes": ["Uses /think and /nothink prefixes, which matches the existing working behavior in this app."]
        },
        {
          "id": "ollama-deepseek-reasoning",
          "label": "DeepSeek Reasoning",
          "match": ["deepseek-r1*", "deepseek-r1-distill*", "deepseek*"],
          "runtime": {
            "reasoning": {
              "enabled": true
            }
          },
          "capabilities": {
            "reasoning": {
              "supported": true,
              "toggle": true,
              "outputChannel": "inline",
              "parameterMode": "slash_commands",
              "defaultEnabled": true
            }
          },
          "notes": ["Reasoning is treated as inline output for local Ollama models."]
        },
        {
          "id": "ollama-gpt-oss-reasoning",
          "label": "GPT OSS / Kimi Reasoning",
          "match": ["gpt-oss*", "openai/gpt-oss-*", "kimi*"],
          "runtime": {
            "reasoning": {
              "enabled": true,
              "effort": "medium"
            }
          },
          "capabilities": {
            "reasoning": {
              "supported": true,
              "toggle": true,
              "effortLevels": ["low", "medium", "high"],
              "outputChannel": "inline",
              "parameterMode": "prompt_hint",
              "defaultEnabled": true
            }
          },
          "notes": ["For GPT OSS / Kimi aliases on Ollama, reasoning is guided with prompt hints instead of slash commands."]
        }
      ]
    },
    "lmstudio": {
      "label": "LM Studio",
      "description": "OpenAI-compatible local server. Reasoning control depends on the loaded model.",
      "catalog": [],
      "settings": {
        "supportsModes": false,
        "supportsCustomModel": true,
        "supportsModelDiscovery": true,
        "supportsRequestOverrides": true,
        "customModelLabel": "Manual Model ID",
