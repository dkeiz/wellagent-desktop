        {
          "id": "openrouter-deepseek-reasoning",
          "label": "DeepSeek Reasoning",
          "match": ["deepseek/deepseek-r1*", "deepseek-r1*"],
          "runtime": {
            "reasoning": {
              "enabled": true
            }
          },
          "capabilities": {
            "reasoning": {
              "supported": true,
              "toggle": true,
              "outputChannel": "separate",
              "parameterMode": "openrouter_reasoning",
              "defaultEnabled": true
