          {
            "id": "apiKey",
            "label": "API Key",
            "type": "password",
            "placeholder": "Optional",
            "required": false,
            "helpText": "Leave blank unless you configured LM Studio to require a bearer token."
          }
        ]
      },
      "runtime": {
        "contextWindow": {
          "value": 8192
        },
        "streaming": {
          "text": false,
          "reasoning": false
        }
      },
      "capabilities": {
        "streaming": {
          "text": true,
          "reasoning": "inline"
        },
        "contextWindow": {
          "supported": true,
          "configurable": true
        },
        "requestOverrides": {
          "supported": true
        }
      },
      "notes": ["LM Studio exposes streaming, but this app currently consumes responses as complete messages."],
      "models": [
        {
          "id": "lmstudio-generic-reasoning",
          "label": "Generic Local Reasoning",
          "match": ["qwen*", "qwq*", "deepseek*", "r1*", "gpt-oss*", "gpt-oss-*", "gpt-oss 120*", "openai/gpt-oss-*"],
          "capabilities": {
            "reasoning": {
              "supported": true,
              "toggle": true,
              "outputChannel": "inline",
              "parameterMode": "prompt_hint",
              "defaultEnabled": false
            }
          },
          "notes": ["LM Studio does not expose a unified reasoning parameter, so the app falls back to prompt guidance."]
        }
      ]
