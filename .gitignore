# Dependencies
node_modules/
mobile/package-lock.json

# Build outputs
dist/
dist_*/
dist-*/
dist_portable_*/
dist_dir_*/
build/
out/

# Electron logs
*.log
*.err.log
*.out.log

# Databases (contain conversations, API keys, personal settings)
*.db
*.sqlite
*.sqlite3

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.vs/
.idea/
*.swp
*.swo

# Environment / secrets
.env
.env.local
.env.production

# Temporary files
*.tmp
temp/
data/tmp/
data/whisper-cache/
window_dump*.xml
agentin/*window_dump*.xml

# Debug capture screenshots
agentin/localagent-*.png

# ===== RUNTIME ARTIFACTS (never ship) =====

# A2A protocol runtime data (task history, event logs)
agentin/a2a/tasks/
agentin/a2a/events/

# Runtime task queue state
agentin/tasks/

# Generated sub-agent verifier folders
agentin/agents/sub/*-[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]*/

# Python bytecode
**/__pycache__/
*.pyc
*.pyo

# ===== PERSONAL / PRIVATE RUNTIME DATA =====

# Runtime memory files are local-only. Keep marker/docs files trackable.
agentin/memory/**
!agentin/memory/
!agentin/memory/README.md
!agentin/memory/.gitignore
!agentin/memory/.gitkeep

# User profile memory (contains personal observations, health data, location, habits)
agentin/userabout/memoryaboutuser.md

# Daily memory logs (personal session observations)
agentin/memory/daily/*.md

# Global user preferences and personal data
agentin/memory/global/preferences.md

# Memory images and task data
agentin/memory/images/
agentin/memory/tasks/

# Per-agent runtime memory/state (generated automatically at runtime)
agentin/agents/pro/*/memory/compact.md
agentin/agents/pro/*/config/state.json

# Session workspaces (contain personal work artifacts)
agentin/workspaces/*/

# Run artifacts (generated at runtime, may contain personal data)
agentin/subtasks/runs/
agentin/research/runs/
agentin/workflows/runs/
agentin/workflows/runtime_workflow_persist_*.json

# Knowledge staging (user-generated, not curated)
agentin/knowledge/staging/*/

# Plugin runtime state
agentin/plugins/agent-rag-studio/data/state.json
agentin/plugins/http-tts-bridge/runtime/

# Memory hashes (runtime state)
agentin/memory/.hashes.json

# ===== DEVELOPMENT SCRATCH =====

# Development archive (kept locally, not shipped)
developing_archive/

# UI concept prototypes
ui-concepts/

# Scratch files
tmp.txt

# Release archives kept locally outside the public source surface
releases/android/archive/

# ===== PRESERVE DIRECTORY STRUCTURE =====
# .gitkeep files are explicitly tracked
!**/.gitkeep
!**/.gitignore
